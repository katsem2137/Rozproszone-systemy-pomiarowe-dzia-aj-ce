# =============================================================
# Plik konfiguracyjny - skopiuj jako .env i uzupełnij wartości
# cp .env.example .env
# NIGDY nie commituj pliku .env do repozytorium!
# =============================================================

# PostgreSQL - dane połączenia
# DB_HOST to nazwa kontenera w Docker Compose, zazwyczaj nie trzeba zmieniać
DB_HOST=postgres

# Nazwa bazy danych
DB_NAME=

# Użytkownik bazy danych
DB_USER=

# Hasło użytkownika bazy danych
DB_PASSWORD=

# REST API - HTTP Basic Auth (lab 11)
# Dane logowania do chronionych endpointow API (/devices, /latest, /history, ...)
API_USERNAME=
API_PASSWORD=
